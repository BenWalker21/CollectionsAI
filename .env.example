# Local server
PORT=4173
APP_BASE_URL=http://localhost:4173

# Stripe subscriptions
# Create a subscription price in Stripe and add these before taking payments.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:4173/demo/?paid=success
STRIPE_CANCEL_URL=http://localhost:4173/#paid

# QuickBooks Online / Intuit OAuth
# Create these in the Intuit Developer dashboard.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4173/api/qbo/callback

# Gmail / Google OAuth
# Create these in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4173/api/gmail/callback

# Outlook / Microsoft Graph OAuth
# Create these in Microsoft Azure App registrations.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4173/api/outlook/callback
